# ============================================================================
# Atlantic eSIM Platform - Environment Configuration Template
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore for security
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/atlantic_esim?schema=public"

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET="dev-secret-key-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ============================================================================
# CACHE & SESSION
# ============================================================================
REDIS_URL="redis://localhost:6379"

# ============================================================================
# PROVIDER API KEYS
# ============================================================================
# Get these from each provider's dashboard
# For development: Use sandbox/test keys
# For production: Use live keys from AWS Secrets Manager

AIRALO_API_KEY="your-airalo-api-key"
AIRALO_API_URL="https://sandbox-api.airalo.com"

MAYA_MOBILE_API_KEY="your-maya-mobile-api-key"
MAYA_MOBILE_API_URL="https://sandbox.mayamobile.com/api"

ESIMCARD_API_KEY="QVjZf83Mp2wPV7RLdZb6FeGfz4MNoPVdOJKeFBWH
ESIMCARD_API_URL="https://sandbox.esimcard.com/api"

BREEZE_API_KEY="your-breeze-api-key"
BREEZE_API_URL="https://sandbox.breeze.com/api"

HOLAFLY_API_KEY="your-holafly-api-key"
HOLAFLY_API_URL="https://sandbox.holafly.com/api"

eSIM_Go_API_KEY="your-esim-go-api-key"
eSIM_Go_Email_Address="your-esim-go-email@example.com"
ESIM_GO_BASE_URL="https://api.esim-go.com/v2.4"

# ============================================================================
# PAYMENT PROCESSING (STRIPE)
# ============================================================================
# Get from Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Using Gmail SMTP (requires App Password, not regular password)
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_EMAIL="noreply@atlanticesim.com"
SMTP_FROM_NAME="Atlantic eSIM"

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
NODE_ENV="development"
PORT=3002
FRONTEND_URL="http://localhost:3001"
BACKEND_URL="http://localhost:3002"

# ============================================================================
# LOGGING & MONITORING (Optional - for development)
# ============================================================================
LOG_LEVEL="debug"
SENTRY_DSN=""

# ============================================================================
# SECURITY
# ============================================================================
# CORS allowed origins (comma-separated) - used by main.ts
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:5173"
CORS_ORIGINS="http://localhost:3001,http://localhost:5173"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_2FA=false
ENABLE_PAYMENT_PROCESSING=true
ENABLE_EMAIL_NOTIFICATIONS=true

# ============================================================================
# NOTES FOR DEVELOPERS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to git
# 4. For team sharing: Use 1Password, LastPass, or AWS Secrets Manager
# 5. For production: Use AWS Secrets Manager (see PRODUCTION_ROADMAP.md)
# ============================================================================
