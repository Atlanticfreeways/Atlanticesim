generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phone       String?
  name        String
  password    String
  role        UserRole @default(END_USER)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
  esims       ESim[]
  preferences UserPreferences?
  apiTokens   ApiToken[]
  wallet      Wallet?
  partnerProfile PartnerProfile?
  webhookConfig  WebhookConfig?

  @@map("users")
  @@index([email])
  @@index([createdAt])
}

model UserPreferences {
  id               String  @id @default(cuid())
  userId           String  @unique
  preferredCurrency String @default("USD")
  notifications    Boolean @default(true)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model ApiToken {
  id          String   @id @default(cuid())
  userId      String
  name        String
  tokenHash   String   @unique
  lastUsedAt  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
  @@index([userId])
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Decimal  @db.Decimal(15, 2) @default(0.00)
  currency    String   @default("USD")
  updatedAt   DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String           @id @default(cuid())
  walletId    String
  amount      Decimal          @db.Decimal(15, 2)
  type        TransactionType
  description String?
  orderId     String?          @unique
  createdAt   DateTime         @default(now())

  wallet      Wallet @relation(fields: [walletId], references: [id])

  @@map("wallet_transactions")
  @@index([walletId])
  @@index([createdAt])
}

model PartnerProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  companyName     String?
  logoUrl         String?
  primaryColor    String? @default("#000000")
  supportEmail    String?
  customDomain    String? @unique
  wholesaleMargin Decimal @db.Decimal(5, 2) @default(10.00) // Default 10% discount

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("partner_profiles")
}

model WebhookConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  url         String
  secret      String   // For HMAC signing
  isActive    Boolean  @default(true)
  events      String[] // Array of event names like ["order.completed"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("webhook_configs")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ORDER_PAYMENT
  REFUND
}

model Provider {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  apiBaseUrl  String
  isActive    Boolean           @default(true)
  config      Json
  priority    Int               @default(100)
  supportedPackageTypes PackageType[]
  preferredRegions      String[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  defaultMargin Decimal?        @db.Decimal(5, 2)
  fixedMarkup   Decimal?        @db.Decimal(10, 2)

  packages    Package[]
  orders      Order[]
  esims       ESim[]

  @@map("providers")
}

model Package {
  id                String      @id @default(cuid())
  providerId        String
  providerPackageId String
  name              String
  description       String?
  countries         String[]
  regions           String[]
  dataAmount        Int
  dataUnit          DataUnit
  isUnlimited       Boolean     @default(false)
  validityDays      Int
  startType         StartType   @default(IMMEDIATE)
  price             Decimal     @db.Decimal(10, 2)
  retailPriceOverride Decimal?  @db.Decimal(10, 2)
  currency          String      @default("USD")
  features          String[]
  hasVoice          Boolean     @default(false)
  hasSms            Boolean     @default(false)
  voiceMinutes      Int?
  smsCount          Int?
  packageType       PackageType @default(DATA_ONLY)
  scopeType         ScopeType   @default(LOCAL)
  isActive          Boolean     @default(true)
  lastSyncedAt      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])
  orders   Order[]

  @@unique([providerId, providerPackageId])
  @@index([providerId])
  @@index([countries])
  @@index([isActive])
  @@index([packageType, scopeType])
  @@map("packages")
}

model Order {
  id              String        @id @default(cuid())
  userId          String
  packageId       String
  providerId      String
  status          OrderStatus   @default(PENDING)
  paymentAmount   Decimal       @db.Decimal(10, 2)
  paymentCurrency String        @default("USD")
  paymentMethod   String?
  transactionId   String?
  paymentStatus   PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  meta            Json?

  user     User     @relation(fields: [userId], references: [id])
  package  Package  @relation(fields: [packageId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
  esim     ESim?

  @@map("orders")
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}

model ESim {
  id                String    @id @default(cuid())
  orderId           String    @unique
  userId            String
  providerId        String
  iccid             String    @unique
  status            ESimStatus @default(INACTIVE)
  qrCode            String?
  smdpAddress       String?
  activationCode    String?
  confirmationCode  String?
  dataUsed          Int       @default(0)
  dataTotal         Int
  validUntil        DateTime?
  activatedAt       DateTime?
  lastUsageCheck    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order    Order    @relation(fields: [orderId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
  usageHistory UsageUpdate[]

  @@map("esims")
  @@index([iccid])
  @@index([status])
  @@index([userId])
}

model UsageUpdate {
  id          String   @id @default(cuid())
  esimId      String
  dataUsed    Int      // In MB
  timestamp   DateTime @default(now())

  esim        ESim     @relation(fields: [esimId], references: [id], onDelete: Cascade)

  @@map("usage_updates")
  @@index([esimId])
  @@index([timestamp])
}

enum UserRole {
  END_USER
  BUSINESS_PARTNER
  ADMIN
  SUPPORT_AGENT
}

enum DataUnit {
  MB
  GB
}

enum StartType {
  IMMEDIATE
  FIRST_USE
}

enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  ACTIVATED
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ESimStatus {
  INACTIVE
  ACTIVE
  EXPIRED
  DEPLETED
  SUSPENDED
}

enum PackageType {
  DATA_ONLY
  VOICE_ONLY
  TEXT_ONLY
  DATA_WITH_TEXT
  DATA_WITH_CALL
  TEXT_WITH_CALL
  ALL_INCLUSIVE
  DATA_WITH_ALL_UNLIMITED
}

enum ScopeType {
  LOCAL
  REGIONAL
  MULTI_COUNTRY
  GLOBAL
}

model GlobalPricing {
  id            String  @id @default(cuid())
  defaultMargin Decimal @db.Decimal(5, 2) @default(15.00) // 15%
  fixedMarkup   Decimal @db.Decimal(10, 2) @default(0.00)
  updatedAt     DateTime @updatedAt

  @@map("global_pricing")
}