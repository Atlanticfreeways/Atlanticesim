# Atlantic eSIM - Production Environment Configuration
# Copy this to .env.production and fill in actual values

# Application
NODE_ENV=production
PORT=3000
APP_NAME=atlantic-esim
APP_VERSION=3.0.0

# Database
DATABASE_URL=postgresql://user:password@db-host:5432/atlantic_esim_prod
PRISMA_SKIP_VALIDATION_WARNING=true

# Redis
REDIS_URL=redis://redis-host:6379
REDIS_HOST=redis-host
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=24h

# API Keys (Encrypted in database, these are for initial setup)
AIRALO_API_KEY=your-airalo-key
ESIM_GO_API_KEY=your-esim-go-key
MAYA_MOBILE_API_KEY=your-maya-mobile-key
ESIMCARD_API_KEY=your-esimcard-key
BREEZE_API_KEY=your-breeze-key
HOLAFLY_API_KEY=your-holafly-key

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@atlanticesim.com

# AWS (Optional - for S3, SES, etc.)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=atlantic-esim-prod

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=https://atlanticesim.com,https://www.atlanticesim.com
CORS_CREDENTIALS=true

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
DATADOG_API_KEY=your-datadog-key

# Feature Flags
ENABLE_CATALOG_SYNC=true
ENABLE_HEALTH_CHECKS=true
ENABLE_WEBHOOKS=true
ENABLE_ANALYTICS=true

# Timeouts
API_TIMEOUT_MS=30000
PROVIDER_TIMEOUT_MS=10000
SYNC_TIMEOUT_MS=120000

# Sync Configuration
CATALOG_SYNC_INTERVAL=6h
HEALTH_CHECK_INTERVAL=30m
USAGE_SYNC_INTERVAL=6h

# Deployment
DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_VERSION=3.0.0
